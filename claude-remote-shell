#!/usr/bin/env bash
#
# claude-remote-shell — redirect Claude Code's Bash tool commands to a remote machine
#

set -euo pipefail

case "$(basename "$0")" in
claude-remote-shell*)
    # Launcher mode: parse destination and launch Claude with remote shell configured.
    [[ $# -eq 0 ]] && { echo "ℹ️ claude-remote-shell [claude-cmd] [user@]host[:/path] [claude args...]" >&2; exit 1; }

    claude_bin="claude"
    if [[ $# -ge 2 && "$1" != *:* && "$1" != *@* ]]; then
        # Possible custom claude command. Validate by checking via
        # the user's shell (so aliases/functions from rc files work)
        if [[ -n "$SHELL" ]] && "$SHELL" -c "command -v '$1' >/dev/null 2>&1"; then
            claude_bin="$1"
            shift
        elif command -v "$1" &>/dev/null; then
            # Fall back to direct check if SHELL is not set
            claude_bin="$1"
            shift
        else
            echo "Warning: '$1' not found (via $SHELL or command -v), using default 'claude'" >&2
        fi
    fi

    if [[ "$claude_bin" != "claude" ]]; then
        echo "🦀 Using claude command '$claude_bin'"
    fi

    dest="$1"
    shift

    if [[ "$dest" == *:* ]]; then
        host="${dest%%:*}"
        remote_path="${dest#*:}"
    else
        host="$dest"
        remote_path=""
    fi

    echo "📡 Running Bash tool remotely on $host"
    export CLAUDE_REMOTE_HOST="$host"

    # Resolve to absolute path so CLAUDE_CODE_SHELL works from any cwd.
    script="${BASH_SOURCE[0]}"
    if [[ "$script" != /* ]]; then
        script="$(cd "$(dirname "$script")" && pwd)/$(basename "$script")"
    fi

    command -v mutagen &>/dev/null || { echo "⚠️ mutagen is required but not found in PATH" >&2; exit 1; }

    session_dir=$(mktemp -d /tmp/claude-remote-shell.XXXXXX)
    export CLAUDE_REMOTE_SHELL_DIR="$session_dir"
    export TMPDIR="$session_dir/tmp"
    export CLAUDE_CODE_TMPDIR="$TMPDIR/claude-tmp"
    export MUTAGEN_DATA_DIRECTORY="$session_dir/mutagen"
    mkdir -p "$TMPDIR" "$CLAUDE_CODE_TMPDIR" "$MUTAGEN_DATA_DIRECTORY"

    # Handle session start via plugin, as multiple `--settings` will not merge
    mkdir -p "$session_dir/plugin/.claude-plugin" "$session_dir/plugin/hooks"
    cat > "$session_dir/plugin/.claude-plugin/plugin.json" <<'EOF'
{
  "name": "claude-remote-shell",
  "version": "1.0.0",
  "description": "Captures session metadata for claude-remote-shell"
}
EOF

    cat > "$session_dir/plugin/hooks/hooks.json" <<'EOF'
{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start"
          }
        ]
      }
    ]
  }
}
EOF

    ln -sf "$script" "$session_dir/plugin/hooks/session-start"

    export CLAUDE_REMOTE_SSH_OPTIONS="-o StrictHostKeyChecking=yes -o ControlMaster=auto -o ControlPath=$session_dir/ssh-%C -o ControlPersist=yes"

    teardown() {
        mutagen sync terminate --all >/dev/null 2>&1 || true
        mutagen daemon stop 2>/dev/null || true
        ssh $CLAUDE_REMOTE_SSH_OPTIONS "$host" "rm -rf '$session_dir'" 2>/dev/null || true
        ssh -O exit $CLAUDE_REMOTE_SSH_OPTIONS "$host" 2>/dev/null || true
        rm -rf "$session_dir"
    }
    trap teardown EXIT

    mutagen_options=(--sync-mode=two-way-resolved)

    # Optional user-provided Mutagen config file.
    config_file="$(pwd -P)/.claude/remote-shell/mutagen.yml"
    [[ -f "$config_file" ]] && mutagen_options+=(-c "$config_file")

    # Sync the tmpdir, filtered to claude-* files/dirs. This covers both Claude Code's
    # infrastructure files (e.g. cwd tracking) and CLAUDE_CODE_TMPDIR (claude-tmp/),
    # while excluding noise from MCP servers and other infrastructure.
    ssh $CLAUDE_REMOTE_SSH_OPTIONS "$host" "mkdir -p '$CLAUDE_CODE_TMPDIR'"
    mutagen sync terminate claude-tmpdir 2>/dev/null || true
    mutagen sync create \
        --name=claude-tmpdir \
        "${mutagen_options[@]}" \
        --ignore="*" \
        --ignore="!claude-*" \
        --ignore="!claude-*/**" \
        --symlink-mode=posix-raw \
        "$TMPDIR" \
        "$host:$TMPDIR" >/dev/null

    # Optionally sync the project directory if a remote path was given.
    if [[ -n "$remote_path" ]]; then
        project_dir="$(pwd -P)"
        echo "🗂️ Syncing $project_dir ↔ $host:$remote_path"
        mutagen sync terminate claude-project 2>/dev/null || true
        ssh $CLAUDE_REMOTE_SSH_OPTIONS "$host" "mkdir -p '$remote_path'"
        mutagen sync create \
            --name=claude-project \
            "${mutagen_options[@]}" \
            "$project_dir" \
            "$host:$remote_path" >/dev/null
        export CLAUDE_LOCAL_PATH="$project_dir"
        export CLAUDE_REMOTE_PATH="$remote_path"
    fi

    # CLAUDE_CODE_SHELL requires the path to contain "bash" or "zsh".
    # Create a symlink named "bash" in our session tmpdir.
    symlink="$session_dir/bash"
    ln -sf "$script" "$symlink"
    export CLAUDE_CODE_SHELL="$symlink"

    # Give Claude context about the remote shell environment,
    # similar to the existing environment system instruction.
    remote_system=$(ssh $host 'uname -sr' 2>/dev/null)
    remote_system_prompt=$(cat <<EOF
All Bash tool commands run remotely on $host, not locally. You have no local shell access.

Remote environment:
- Platform / OS: $remote_system
- Shell: bash
- TMPDIR: $CLAUDE_CODE_TMPDIR

NEVER assume /tmp — always use \$TMPDIR, including for mktemp.
To check subagent output, ALWAYS use the TaskOutput tool, NEVER Bash.
EOF
)
    if [[ -d ".git" ]]; then
        vcs_ignored=$(mutagen sync list --template '{{json .}}' claude-project 2>/dev/null \
            | jq -r '.[0].ignore.vcs')
        if [[ "$vcs_ignored" == "true" ]]; then
            remote_system_prompt+="Git is not available on the remote (.git is not synced). NEVER run git commands — they will fail."
        fi
    fi

    yolo_opts=""
    [[ "$(basename "$0")" == *-yolo ]] && yolo_opts='--allowedTools Bash(*)'

    claude_args=()
    claude_args+=(--plugin-dir "$session_dir/plugin")
    claude_args+=(--append-system-prompt)
    claude_args+=("$remote_system_prompt")
    [[ -n "$yolo_opts" ]] && claude_args+=("$yolo_opts")
    claude_args+=("$@")

    if [[ -n "$SHELL" ]]; then
        printf -v cmd '%q ' "$claude_bin" "${claude_args[@]}"
        "$SHELL" -l -c "exec $cmd" --
    else
        "$claude_bin" "${claude_args[@]}"
    fi
    ;;

session-start)
    input=$(cat)
    transcript_path=$(printf '%s' "$input" | jq -r '.transcript_path')
    local_session_dir="${transcript_path%.jsonl}"
    session_id=$(basename "$local_session_dir")
    local_project_dir=$(dirname "$local_session_dir")
    remote_project_dir="$CLAUDE_REMOTE_SHELL_DIR/project"
    remote_session_dir="$remote_project_dir/$session_id"

    mkdir -p "$local_session_dir"
    ssh $CLAUDE_REMOTE_SSH_OPTIONS "$CLAUDE_REMOTE_HOST" "mkdir -p '$remote_session_dir'"
    mutagen sync create \
        --name=claude-session-data \
        --sync-mode=one-way-safe \
        --symlink-mode=posix-raw \
        --ignore="*" \
        --ignore="!tool-results" \
        --ignore="!tool-results/**" \
        "$local_session_dir" \
        "$CLAUDE_REMOTE_HOST:$remote_session_dir" >/dev/null

    # Persist path mappings for the bash wrapper via Claude's env mechanism.
    printf 'export CLAUDE_LOCAL_PROJECT_DIR=%q\n' "$local_project_dir" >> "$CLAUDE_ENV_FILE"
    printf 'export CLAUDE_REMOTE_PROJECT_DIR=%q\n' "$remote_project_dir" >> "$CLAUDE_ENV_FILE"
    ;;

bash)
    # Shell-wrapper mode: invoked by Claude Code via the CLAUDE_CODE_SHELL symlink.
    # Args: -c [-l] <command>  (-l present when no shell snapshot exists)
    # The command string is always the last argument.
    cmd="${@: -1}"

    sync_flush() {
        mutagen sync flush --all >/dev/null
    }

    # Translate local paths to remote paths in the command and cwd.
    remote_cwd="$PWD"
    map_path=false
    [[ -n "${CLAUDE_LOCAL_PATH:-}" && "${CLAUDE_LOCAL_PATH:-}" != "${CLAUDE_REMOTE_PATH:-}" ]] && map_path=true

    if $map_path; then
        cmd="${cmd//$CLAUDE_LOCAL_PATH/$CLAUDE_REMOTE_PATH}"
        remote_cwd="${PWD//$CLAUDE_LOCAL_PATH/$CLAUDE_REMOTE_PATH}"
    fi

    # Translate local project-data paths to remote (set up by session-start hook).
    [[ -n "${CLAUDE_LOCAL_PROJECT_DIR:-}" ]] && \
        cmd="${cmd//$CLAUDE_LOCAL_PROJECT_DIR/$CLAUDE_REMOTE_PROJECT_DIR}"

    # Build the remote command: cd to the same cwd, then run the command
    # as-is (including Claude's pwd capture suffix, which writes to the
    # synced tmpdir on the remote and gets flushed back after).
    remote_script='export SHELL=bash TMPDIR="$3" && mkdir -p "$TMPDIR" && cd "$1" && eval "$2"'
    remote_cmd=$(printf 'bash -c %q _ %q %q %q' "$remote_script" "$remote_cwd" "$cmd" "$TMPDIR")

    sync_flush

    if $map_path; then
        # Stream stdout/stderr through FIFOs with awk filters to translate remote paths back to local.
        fifo_dir=$(mktemp -d)
        mkfifo "$fifo_dir/stdout" "$fifo_dir/stderr"

        awk_map_path='BEGIN { gsub(/[][\\^$.|*+?(){}]/, "\\\\&", r) }
            { gsub(r, l); print > out; fflush(out) }'

        awk -v r="$CLAUDE_REMOTE_PATH" -v l="$CLAUDE_LOCAL_PATH" -v out="/dev/stdout" \
            "$awk_map_path" <"$fifo_dir/stdout" &
        stdout_pid=$!

        awk -v r="$CLAUDE_REMOTE_PATH" -v l="$CLAUDE_LOCAL_PATH" -v out="/dev/stderr" \
            "$awk_map_path" <"$fifo_dir/stderr" &
        stderr_pid=$!

        ssh $CLAUDE_REMOTE_SSH_OPTIONS "$CLAUDE_REMOTE_HOST" "$remote_cmd" \
            >"$fifo_dir/stdout" 2>"$fifo_dir/stderr"
        exit_code=$?

        wait "$stdout_pid" "$stderr_pid" 2>/dev/null || true
        rm -rf "$fifo_dir"
    else
        ssh $CLAUDE_REMOTE_SSH_OPTIONS "$CLAUDE_REMOTE_HOST" "$remote_cmd"
        exit_code=$?
    fi

    sync_flush

    exit $exit_code
    ;;
esac
